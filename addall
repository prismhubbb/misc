-- SERVER HOPPING (ACTUALLY WORKS NOW)
local function serverHop()
    if isHopping then return end
    isHopping = true
    
    local placeId = game.PlaceId
    local attempts = 0
    local maxAttempts = 50  -- Try up to 50 servers before giving up
    
    while attempts < maxAttempts do
        attempts = attempts + 1
        
        local url = string.format("https://games.roblox.com/v1/games/%d/servers/Public?sortOrder=Desc&limit=100", placeId)
        
        local success, data = pcall(function()
            return http:JSONDecode(game:HttpGet(url))
        end)
        
        if success and data and data.data then
            local validServers = {}
            
            -- Filter servers with 90+ players
            for _, server in ipairs(data.data) do
                if server.playing and server.playing >= 90 and server.id ~= game.JobId then
                    table.insert(validServers, server)
                end
            end
            
            -- Try each valid server
            for _, server in ipairs(validServers) do
                local hopSuccess, hopError = pcall(function()
                    ts:TeleportToPlaceInstance(placeId, server.id, lp)
                end)
                
                if hopSuccess then
                    -- Success, we're teleporting
                    return
                end
                -- If failed (server full), continue to next server silently
            end
        end
        
        -- Wait before next batch of servers
        task.wait(2)
    end
    
    -- If we exhausted all attempts, just teleport to any server
    pcall(function()
        ts:Teleport(placeId)
    end)
end

