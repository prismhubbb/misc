-- 2. SERVER HOPPING FUNCTION (Moved up to avoid errors)
local function serverHop()
    if isHopping then return end
    isHopping = true
    local currentId = game.PlaceId
    
    for i = 1, 10 do
        local success, result = pcall(function()
            return http:JSONDecode(game:HttpGet("https://roblox.com" .. currentId .. "/servers/Public?sortOrder=Desc&limit=100")).data
        end)
        if success and result then
            for _, server in ipairs(result) do
                if server.playing >= 90 and server.id ~= game.JobId then
                    ts:TeleportToPlaceInstance(currentId, server.id, lp)
                    task.wait(2)
                end
            end
        end
        task.wait(2)
    end
    ts:Teleport(currentId)
end

