-- AUTOMATED FRIEND REQUEST
local function inviteAll()
    if busy then return end
    busy = true
    addBtn.Text = "SENDING..."
    addBtn.BackgroundColor3 = Color3.fromRGB(90, 200, 60)
    
    local sent = 0
    local already = 0
    local failed = 0
    local consecutive = 0
    
    for _, player in ipairs(plrs:GetPlayers()) do
        if player ~= lp then
            local isFriend = false
            pcall(function()
                isFriend = lp:IsFriendsWith(player.UserId)
            end)
            
            if not isFriend then
                local success = pcall(function()
                    lp:RequestFriendship(player)
                end)
                
                if success then
                    sent = sent + 1
                    consecutive = consecutive + 1
                    stats.Text = string.format("Sent: %d | Already: %d | Failed: %d", sent, already, failed)
                else
                    failed = failed + 1
                end
            else
                already = already + 1
            end
            
            local delay = 1.2 + (math.random(-200, 300) / 1000)
            if consecutive > 0 and consecutive % 10 == 0 then
                delay = delay + math.random(2, 4)
                stats.Text = "Pattern break delay..."
            end
            
            task.wait(delay)
        end
    end
    
    task.wait(1)
    stats.Text = string.format("✓ Complete - Sent: %d | Already: %d", sent, already)
    addBtn.Text = "ADD ALL PLAYERS"
    addBtn.BackgroundColor3 = Color3.fromRGB(122, 255, 82)
    busy = false
end

addBtn.MouseButton1Click:Connect(inviteAll)

