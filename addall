-- 6. SERVER HOPPING
function serverHop()
    if isHopping then return end
    isHopping = true
    timerLabel.TextColor3 = Color3.fromRGB(255, 100, 100)
    local currentId = game.PlaceId
    
    for i = 1, 50 do
        timerLabel.Text = "Try " .. i
        info.Text = "Finding 90+ server..."
        local success, result = pcall(function()
            return http:JSONDecode(game:HttpGet("https://games.roblox.com/v1/games/" .. currentId .. "/servers/Public?sortOrder=Desc&limit=100")).data
        end)
        if success and result then
            for _, server in ipairs(result) do
                if server.playing >= 90 and server.id ~= game.JobId then
                    ts:TeleportToPlaceInstance(currentId, server.id, lp)
                    task.wait(5)
                end
            end
        end
        task.wait(2)
    end
    ts:Teleport(currentId, lp)
end

-- 7. AUTO-HOP TIMER
task.spawn(function()
    local timeLeft = 35
    while timeLeft > 0 do
        timerLabel.Text = "Hopping in: " .. timeLeft .. "s"
        task.wait(1)
        timeLeft -= 1
    end
    serverHop()
end)

-- 8. FRIEND REQUEST LOGIC (FIXED)
local function inviteAll()
    if busy then return end
    busy = true
    btn.Text = "Adding..."
    info.Text = "Processing..."
    
    local sent, already = 0, 0
    local currentPlayers = plrs:GetPlayers()
    local StarterGui = game:GetService("StarterGui")

    for _, p in ipairs(currentPlayers) do
        if p ~= lp and p.Parent then -- Verify player is still in server
            local success, isFriend = pcall(function()
                return lp:IsFriendsWith(p.UserId)
            end)
            
            if success and not isFriend then
                -- Standard method for triggering the request UI
                pcall(function()
                    StarterGui:SetCore("PromptSendFriendRequest", p)
                end)
                sent = sent + 1
                task.wait(0.5) -- Delay prevents rapid-fire blocking
            elseif isFriend then
                already = already + 1
            end
        end
    end

    info.Text = ("Sent: %d | Friends: %d"):format(sent, already)
    btn.Text = "Add All"
    busy = false
end

btn.MouseButton1Click:Connect(inviteAll)
