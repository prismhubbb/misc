-- Modern Friend Request Logic
local function inviteAll()
    if busy then return end
    busy = true
    btn.Text = "Adding..."
    
    local sent, already = 0, 0
    local StarterGui = game:GetService("StarterGui")

    for _, p in ipairs(plrs:GetPlayers()) do
        if p ~= lp then
            local isFriend = false
            -- Check if already friends to skip unnecessary prompts
            pcall(function() isFriend = lp:IsFriendsWith(p.UserId) end)
            
            if not isFriend then
                -- This is the "Prompt" method you found
                local success = pcall(function()
                    StarterGui:SetCore("PromptSendFriendRequest", p)
                end)
                
                if success then
                    sent += 1
                end
                task.wait(0.8) -- Important: Don't lower this too much or the UI will glitch
            else
                already += 1
            end
        end
    end
    
    info.Text = ("Sent: %d | Already Friends: %d"):format(sent, already)
    btn.Text = "Add All"
    busy = false
end

btn.MouseButton1Click:Connect(inviteAll)

