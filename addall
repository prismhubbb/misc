-- 5. HIGH-PERFORMANCE SERVER HOPPING (DYNAMIC ID)
function serverHop()
	if isHopping then return end
	isHopping = true
	
	timerLabel.TextColor3 = Color3.fromRGB(255, 100, 100)
	local currentId = game.PlaceId
	
	for i = 1, 50 do
		timerLabel.Text = "Try " .. i
		info.Text = "Finding 90+ server..."
		
		local success, result = pcall(function()
			return http:JSONDecode(game:HttpGet("https://games.roblox.com/v1/games/" .. currentId .. "/servers/Public?sortOrder=Desc&limit=100")).data
		end)

		if success and result then
			for _, server in ipairs(result) do
				if server.playing >= 90 and server.id ~= game.JobId then
					info.Text = "Joining " .. server.playing .. " plrs..."
					
					local blankGui = Instance.new("ScreenGui")
					ts:SetTeleportGui(blankGui)
					
					ts:TeleportToPlaceInstance(currentId, server.id, lp)
					
					task.wait(5) 
					info.Text = "Retrying hop..."
				end
			end
		end
		
		task.wait(2)
	end
	
	ts:Teleport(currentId, lp)
end

-- 6. AUTO-HOP TIMER
task.spawn(function()
	local timeLeft = 35
	while timeLeft > 0 do
		timerLabel.Text = "Hopping in: " .. timeLeft .. "s"
		task.wait(1)
		timeLeft -= 1
	end
	serverHop()
end)

-- 7. FRIEND REQUEST LOGIC
local function inviteAll()
	if busy then return end
	busy = true

	btn.AutoButtonColor = false
	btn.Text = "Adding..."
	info.Text = "Processing requests..."
	
	local sent, already = 0, 0

	for _, p in ipairs(plrs:GetPlayers()) do
		if p ~= lp then
			local okCheck, isFriend = pcall(function()
				return lp:IsFriendsWith(p.UserId)
			end)
			if okCheck and isFriend then
				already += 1
			else
				local okSend = pcall(function()
					lp:RequestFriendship(p)
				end)
				if okSend then
					sent += 1
				end
				task.wait(0.5)
			end
		end
	end

	info.Text = ("Sent: %d | Friends: %d"):format(sent, already)
	btn.Text = "Add All"
	btn.AutoButtonColor = true
	busy = false
end

btn.MouseButton1Click:Connect(inviteAll)
