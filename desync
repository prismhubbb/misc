-- [[ 7. REFACTORED TOGGLE FACTORY ]]
local function CreateToggle(name, configKey, yPos, callback)
    local TContainer = Instance.new("Frame", MainFrame)
    TContainer.BackgroundColor3 = Color3.fromRGB(20, 20, 25); TContainer.Position = UDim2.new(0.05, 0, 0, yPos); TContainer.Size = UDim2.new(0.9, 0, 0, 55)
    Instance.new("UICorner", TContainer).CornerRadius = UDim.new(0, 10)

    local Label = Instance.new("TextLabel", TContainer)
    Label.BackgroundTransparency = 1; Label.Position = UDim2.new(0, 15, 0, 0); Label.Size = UDim2.new(0.6, 0, 1, 0)
    Label.Font = "GothamMedium"; Label.Text = name; Label.TextColor3 = Color3.fromRGB(220, 220, 220); Label.TextSize = 14; Label.TextXAlignment = "Left"

    local Switch = Instance.new("TextButton", TContainer)
    Switch.BackgroundColor3 = Config[configKey] and Color3.fromRGB(110, 115, 255) or Color3.fromRGB(40, 40, 48)
    Switch.Position = UDim2.new(1, -60, 0.5, -13); Switch.Size = UDim2.new(0, 48, 0, 26); Switch.Text = ""
    Instance.new("UICorner", Switch).CornerRadius = UDim.new(1, 0)

    local Bullet = Instance.new("Frame", Switch)
    Bullet.BackgroundColor3 = Color3.new(1,1,1); Bullet.Position = Config[configKey] and UDim2.new(1, -22, 0.5, -9) or UDim2.new(0, 4, 0.5, -9)
    Bullet.Size = UDim2.new(0, 18, 0, 18); Instance.new("UICorner", Bullet).CornerRadius = UDim.new(1, 0)

    task.spawn(function() callback(Config[configKey], true) end)

    Switch.MouseButton1Click:Connect(function()
        Config[configKey] = not Config[configKey]
        local active = Config[configKey]
        
        TweenService:Create(Bullet, TweenInfo.new(0.2, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
            Position = active and UDim2.new(1, -22, 0.5, -9) or UDim2.new(0, 4, 0.5, -9)
        }):Play()
        TweenService:Create(Switch, TweenInfo.new(0.2), {
            BackgroundColor3 = active and Color3.fromRGB(110, 115, 255) or Color3.fromRGB(40, 40, 48)
        }):Play()
        
        Save()
        callback(active, false)
    end)
end

