-- [[ 1. THE NUCLEAR PURGE ]]
local function Purge()
    local names = {"PrismHub_V2", "PrismHub_V4", "PrismHub_Final", "PrismHub_V12", "PrismHub_V13", "PrismHub_V14", "PrismHub_V15", "PrismHub_V16", "PrismHub_V17", "ServerPosVisual"}
    for _, loc in pairs({CoreGui, LP:FindFirstChild("PlayerGui"), workspace}) do
        if loc then
            for _, child in pairs(loc:GetChildren()) do
                for _, name in pairs(names) do
                    if child.Name == name or child:FindFirstChild("PRISM HUB") then
                        child:Destroy()
                    end
                end
            end
        end
    end
end
Purge()

-- [[ 2. UNIFIED CONFIG SYSTEM ]]
local FOLDER_NAME = "PrismHub_Configs"
local FILE_NAME = FOLDER_NAME .. "/master_settings.json" -- Unified filename
local Config = { Desync = false, Unwalk = false, ServerPos = false }

if not isfolder(FOLDER_NAME) then makefolder(FOLDER_NAME) end

local function Save() 
    pcall(function() 
        writefile(FILE_NAME, HttpService:JSONEncode(Config)) 
    end)
end

local function Load()
    if isfile(FILE_NAME) then
        local success, result = pcall(function() return HttpService:JSONDecode(readfile(FILE_NAME)) end)
        if success and type(result) == "table" then
            for k, v in pairs(result) do 
                if Config[k] ~= nil then Config[k] = v end 
            end
        end
    end
end
Load()

