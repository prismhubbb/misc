    local s = Instance.new("UIStroke", Notif)
    s.Thickness = 1.5; s.Color = state and Color3.fromRGB(110, 115, 255) or Color3.fromRGB(255, 80, 80)

    local Icon = Instance.new("ImageLabel", Notif)
    Icon.BackgroundTransparency = 1; Icon.Position = UDim2.new(0, 15, 0.5, -15); Icon.Size = UDim2.new(0, 30, 0, 30)
    Icon.Image = "rbxassetid://6034293019"; Icon.ImageColor3 = s.Color

    local t = Instance.new("TextLabel", Notif)
    t.Size = UDim2.new(1, -60, 0, 20); t.Position = UDim2.new(0, 55, 0, 12)
    t.BackgroundTransparency = 1; t.Font = "GothamBold"; t.TextColor3 = Color3.new(1,1,1); t.Text = title:upper(); t.TextSize = 13; t.TextXAlignment = "Left"

    local d = Instance.new("TextLabel", Notif)
    d.Size = UDim2.new(1, -60, 0, 20); d.Position = UDim2.new(0, 55, 0, 30)
    d.BackgroundTransparency = 1; d.Font = "Gotham"; d.TextColor3 = Color3.fromRGB(180, 180, 180); d.Text = text; d.TextSize = 12; d.TextXAlignment = "Left"

    Notif:TweenPosition(UDim2.new(1, -280, 0.9, -60), "Out", "Back", 0.5, true)
    task.delay(3, function()
        if Notif and Notif.Parent then
            Notif:TweenPosition(UDim2.new(1, 300, 0.9, -60), "In", "Quint", 0.5, true)
            task.wait(0.5); if Notif then Notif:Destroy() end
        end
    end)
end

