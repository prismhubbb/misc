RunService.PostSimulation:Connect(function()
    if LP.Character and LP.Character:FindFirstChild("HumanoidRootPart") then
        local root = LP.Character.HumanoidRootPart
        if not Config.Desync then
            currentServerPos = root.Position
        else
            local delta = (root.Position - lastKnownLocalPos).Magnitude
            if delta > 1.5 and delta < 500 then currentServerPos = root.Position end
        end
        lastKnownLocalPos = root.Position
        if Config.ServerPos then
            ServerPosPart.Position = currentServerPos
            Ring.CFrame = CFrame.new(currentServerPos) * CFrame.Angles(math.rad(90), 0, math.rad(tick()*90))
            local color = Color3.fromHSV(tick() % 4 / 4, 0.8, 1)
            Ring.Color = color; TagStroke.Color = color
            DistLabel.Text = string.format("%.1fm", (root.Position - currentServerPos).Magnitude)
            ServerPosPart.Parent = workspace
        else ServerPosPart.Parent = nil end
    end
end)

