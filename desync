CreateToggle("Unwalk (Idle)", "Unwalk", 120, function(state, silent)
    local c = LP.Character; local h = c and c:FindFirstChildOfClass("Humanoid")
    local a = c and c:FindFirstChild("Animate")
    
    if state then
        if a then a.Disabled = true end
        if h then 
            for _, v in pairs(h:GetPlayingAnimationTracks()) do v:Stop() end
            local idle = a and a:FindFirstChild("idle") and a.idle:FindFirstChildOfClass("Animation")
            if idle then local t = h:LoadAnimation(idle); t.Looped = true; t:Play() end
        end
    else
        if a then a.Disabled = false end
    end
    if not silent then Notify("Unwalk", state and "Idle Lock Active" or "Animations Restored", state) end
end)

