-- Player List
local scroll = Instance.new("ScrollingFrame", fr)
scroll.Size = UDim2.new(1, -40, 0, 140)
scroll.Position = UDim2.new(0, 20, 0, 65)
scroll.BackgroundTransparency = 1
scroll.BorderSizePixel = 0
scroll.ScrollBarThickness = 0
scroll.CanvasSize = UDim2.new(0, 0, 0, 0)

local listLayout = Instance.new("UIListLayout", scroll)
listLayout.Padding = UDim.new(0, 6)

local selectedPlayer = nil

local function updateList()
	for _, child in ipairs(scroll:GetChildren()) do
		if child:IsA("TextButton") then child:Destroy() end
	end
	for _, p in ipairs(plrs:GetPlayers()) do
		if p == lp then continue end
		local pBtn = Instance.new("TextButton", scroll)
		pBtn.Size = UDim2.new(1, 0, 0, 34)
		pBtn.BackgroundColor3 = (selectedPlayer == p) and Color3.fromRGB(25, 25, 25) or Color3.fromRGB(12, 12, 12)
		pBtn.Text = "  " .. p.DisplayName
		pBtn.Font = Enum.Font.GothamMedium
		pBtn.TextColor3 = Color3.fromRGB(220, 220, 220)
		pBtn.TextSize = 11
		pBtn.TextXAlignment = Enum.TextXAlignment.Left
		Instance.new("UICorner", pBtn).CornerRadius = UDim.new(0, 8)
		local tick = Instance.new("TextLabel", pBtn)
		tick.Size = UDim2.new(0, 30, 1, 0)
		tick.Position = UDim2.new(1, -35, 0, 0)
		tick.BackgroundTransparency = 1
		tick.Text = (selectedPlayer == p) and "✓" or ""
		tick.TextColor3 = Color3.fromRGB(255, 255, 255)
		tick.Font = Enum.Font.GothamBold
		tick.TextSize = 14
		pBtn.MouseButton1Click:Connect(function()
			selectedPlayer = p
			updateList()
		end)
	end
	scroll.CanvasSize = UDim2.new(0, 0, 0, listLayout.AbsoluteContentSize.Y)
end
plrs.PlayerAdded:Connect(updateList)
plrs.PlayerRemoving:Connect(function(p) if selectedPlayer == p then selectedPlayer = nil end updateList() end)
updateList()

-- Helper to style buttons
local function styleButton(button)
    button.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
    button.Font = Enum.Font.GothamBold
    button.TextColor3 = Color3.fromRGB(255, 255, 255)
    button.TextSize = 11
    button.AutoButtonColor = false
    
    local corner = Instance.new("UICorner", button)
    corner.CornerRadius = UDim.new(0, 10)
    
    local stroke = Instance.new("UIStroke", button)
    stroke.Color = Color3.fromRGB(50, 50, 50)
    stroke.Thickness = 1
    stroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    
    local bullet = Instance.new("Frame", button)
    bullet.Name = "Bullet"
    bullet.Size = UDim2.fromOffset(6, 6)
    bullet.Position = UDim2.new(0, 15, 0.5, -3)
    bullet.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    bullet.BorderSizePixel = 0
    Instance.new("UICorner", bullet).CornerRadius = UDim.new(1, 0)

    local originalSize = button.Size
    local hoverSize = UDim2.new(originalSize.X.Scale, originalSize.X.Offset + 12, originalSize.Y.Scale, originalSize.Y.Offset + 4)
    local tInfo = TweenInfo.new(0.2, Enum.EasingStyle.Quart, Enum.EasingDirection.Out)

    button.MouseEnter:Connect(function()
        ts:Create(button, tInfo, {Size = hoverSize, TextSize = 13}):Play()
        ts:Create(stroke, tInfo, {Color = Color3.fromRGB(255, 255, 255)}):Play()
    end)
    button.MouseLeave:Connect(function()
        ts:Create(button, tInfo, {Size = originalSize, TextSize = 11}):Play()
        ts:Create(stroke, tInfo, {Color = Color3.fromRGB(50, 50, 50)}):Play()
    end)
    return bullet
end

