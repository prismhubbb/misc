-- CLEANUP LOGIC: Destroys ANY existing version of the GUI before creating a new one
local function clearOldGuis()
    local pGui = lp:FindFirstChild("PlayerGui")
    if pGui then
        for _, child in ipairs(pGui:GetChildren()) do
            if child.Name == "PrismAdder_GUI" then
                child:Destroy()
            end
        end
    end
end
clearOldGuis()

